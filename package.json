{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "core-api:build": "typedoc",
    "build": "next build",
    "dev": "next dev",
    "prebuild": "node scripts/prebuild.mjs",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,json}": [
      "pnpm format"
    ]
  },
  "dependencies": {
    "fumadocs-core": "16.9.1",
    "fumadocs-mdx": "15.0.8",
    "fumadocs-twoslash": "^3.2.0",
    "fumadocs-typescript": "^5.2.6",
    "fumadocs-ui": "16.9.1",
    "hoshimi": "0.3.10-dev-25604872531.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  }
}
